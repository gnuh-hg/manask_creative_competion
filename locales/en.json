    "hero": {
      "badge": "✦ About Us",
      "title_line1": "Task management",
      "title_line2": "more organized every day",
      "subtitle": "Manask is a web-based task management app structured around Folder → Project → Task, combined with a Pomodoro timer and detailed performance statistics — helping you work more organized every day.",
      "stat_levels_number": "3",
      "stat_levels_label": "Management Levels",
      "stat_features_number": "5+",
      "stat_features_label": "Core Features",
      "stat_members_number": "3",
      "stat_members_label": "Members"
    },
    "problem": {
      "tag": "Problem",
      "title": "Why do you need Manask?",
      "desc": "Students, office workers, and freelancers all face the same challenge that hasn't been fully solved.",
      "card1_title": "Scattered lists, no structure",
      "card1_desc": "Paper notes, simple to-do apps, or phone notes are all insufficient when the number of tasks grows. Everything mixes together, hard to categorize and easy to miss.",
      "card2_title": "Not knowing what to prioritize",
      "card2_desc": "When every task looks equally important, users easily fall into a state of busyness without effectiveness — doing a lot but finishing little.",
      "card3_title": "Fragmented tools, multiple apps needed",
      "card3_desc": "To-do list in one place, Pomodoro timer elsewhere, habit tracker somewhere else. Switching between apps breaks focus and wastes time."
    },
    "mission": {
      "tag": "Mission",
      "title": "Manask was built to solve that",
      "desc1": "Instead of a flat list, Manask allows task hierarchy across 3 clear levels: <strong style=\"color:var(--text-primary)\">Folder → Project → Task</strong>. Each task is fully attributed: priority level, start date, due date, notes, and time spent.",
      "desc2": "The <strong style=\"color:var(--text-primary)\">Pomodoro</strong> technique is integrated directly into the workflow — no app switching needed. Users simply select the active task and start focusing immediately.",
      "desc3": "All activity is recorded and displayed through a <strong style=\"color:var(--text-primary)\">visual statistics system</strong>: heatmap, line chart, donut chart — helping you review and improve performance over time."
    },
    "features": {
      "tag": "Features",
      "title": "Everything you need in one place",
      "desc": "No need for 3 separate apps. Manask unifies task organization, focus, and statistics into a single interface.",
      "card1_title": "Folder → Project → Task",
      "card1_desc": "A 3-level structure gives every task a clear place. Folders group large projects, Projects manage individual goals, Tasks are the specific things to do.",
      "card2_title": "Detailed task attributes",
      "card2_desc": "Each task has: priority level (High / Medium / Low), start date, due date, notes, and time spent — enough to accurately assess actual effort.",
      "card3_title": "Built-in Pomodoro",
      "card3_desc": "Select the active task, start the timer, and focus. Customize Focus, Short Break, and Long Break durations. No app switching — everything is right inside Manask.",
      "card4_title": "Visual statistics",
      "card4_desc": "365-day activity heatmap, Donut chart by project distribution, Line chart trends for 7 days / 30 days / 12 months. Review performance and adjust your plan.",
      "card5_title": "Personal account",
      "card5_desc": "Sign up, log in, and store all data securely. Every folder, project, and task is synced separately per account.",
      "card6_title": "Lightweight & No install",
      "card6_desc": "Web app that runs directly in the browser, no installation needed. Dark mode by default, fully responsive — works on any device."
    },
    "how": {
      "tag": "How it works",
      "title": "Get started in just 4 steps",
      "desc": "No lengthy instructions needed. Manask is designed so anyone can start using it right away.",
      "step1_title": "Create Folders & Projects",
      "step1_desc": "Create Folders to group related projects (e.g. \"Semester 2\", \"Work\"). Inside, create Projects for each specific goal.",
      "step2_title": "Add detailed Tasks",
      "step2_desc": "Create tasks with a name, priority level, start date, due date, and notes. Everything is organized clearly, no mixing up.",
      "step3_title": "Start Pomodoro & work",
      "step3_desc": "Select the active task, start the timer, and focus in cycles. Take short breaks between sessions to maintain energy.",
      "step4_title": "Review statistics & improve",
      "step4_desc": "Look back at activity heatmaps, trend charts, and streaks. Understand your work habits and adjust your weekly/monthly plan."
    },
    "screenshots": {
      "tag": "Interface",
      "title": "Designed to be easy to use",
      "desc": "Dark mode, fully responsive, every screen is optimized for the best user experience."
    },
    "team": {
      "tag": "Team",
      "title": "The people behind Manask",
      "desc": "Three students with one common goal: making task management truly organized.",
      "member1_name": "Nguyễn Mạnh Hùng",
      "member1_role": "Frontend Developer",
      "member1_bio": "Responsible for designing and building the entire user interface — from layout and animations to smooth interactive experiences.",
      "member2_name": "Nguyễn Phú Bình",
      "member2_role": "Backend Developer",
      "member2_bio": "Builds the server system, RESTful API, and database — ensuring every feature runs stably, securely, and efficiently.",
      "member3_name": "Nguyễn Bùi Nguyên",
      "member3_role": "Designer",
      "member3_bio": "Responsible for the entire visual direction and user experience — from UX research and wireframes to a consistent design system."
    },
